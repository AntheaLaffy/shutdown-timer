{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shutdown Timer",
  "version": "0.1.0",
  "identifier": "com.shutdown.timer",
  "build": {
    "beforeBuildCommand": "cd ../src && npm run build",
    "frontendDist": "./dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Shutdown Timer",
        "width": 480,
        "height": 600,
        "resizable": true,
        "minWidth": 460,
        "minHeight": 560,
        "decorations": true,
        "transparent": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}